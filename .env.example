# Google Places API Key
# Get your free API key from: https://console.cloud.google.com/apis/credentials
# Enable the Places API in your Google Cloud Project
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Cloudinary URL (cloud storage for images and data)
# Format: cloudinary://api_key:api_secret@cloud_name
# Set this in your hosting environment (e.g. Render environment variables)
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name

# Unsplash Access Key (Optional - for higher quality images)
# Get your free API key from: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
